{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "image": {
      "type": "string",
      "pattern": "^\\/images\\/.*"
    },
    "progress": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "wishlistUrl": {
      "type": "string",
      "format": "uri"
    },
    "en": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "price": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "title",
        "description",
        "price"
      ]
    },
    "ru": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "price": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "title",
        "description",
        "price"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "image",
    "en",
    "ru"
  ]
}
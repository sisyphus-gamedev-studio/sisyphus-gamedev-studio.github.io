{
  "$ref": "#/definitions/projects",
  "definitions": {
    "projects": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "image": {
          "type": "string",
          "pattern": "^\\/images\\/"
        },
        "progress": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "wishlistUrl": {
          "type": "string",
          "format": "uri"
        },
        "en": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "price": {
              "type": "string",
              "minLength": 1
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "title",
            "description",
            "price"
          ],
          "additionalProperties": false
        },
        "ru": {
          "$ref": "#/definitions/projects/properties/en"
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "image",
        "en",
        "ru"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
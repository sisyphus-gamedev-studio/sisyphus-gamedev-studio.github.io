{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "isoDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "image": {
      "type": "string",
      "pattern": "^\\/images\\/.*"
    },
    "type": {
      "default": "update",
      "type": "string",
      "enum": [
        "announcement",
        "dev-diary",
        "update"
      ]
    },
    "en": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "date": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "title",
        "date",
        "summary",
        "body"
      ]
    },
    "ru": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "date": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "body": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "title",
        "date",
        "summary",
        "body"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "isoDate",
    "image",
    "en",
    "ru"
  ]
}
---
import type { Language, TranslationStructure } from "../../types";
import { CAREER_STACK } from "../../config/careers";
import { URLS } from "../../config";
import CareersFAQ from "../features/CareersFAQ";

interface Props {
  t: TranslationStructure["careers"];
  lang: Language;
}

const { t, lang } = Astro.props;

const formUrl = URLS.careersForm;
---

<section id="careers" class="site-section site-section--filled" aria-labelledby="careers-heading">
  <div class="site-section__container">
    <div class="site-section__head reveal">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-label">{t.sectionLabel}</span>
      </div>
      <h2 id="careers-heading" class="t-display-md section-heading">
        {t.heading}<span class="section-heading__accent"> {t.headingSuffix}</span>
      </h2>
    </div>

    <div class="careers-layout">
      <div class="reveal-left">
        <p class="t-body-lg section-lead careers-intro">{t.description}</p>

        <div class="careers-block careers-stack">
          <p class="t-eyebrow-accent careers-block__title">{t.stackTitle}</p>
          <dl class="careers-stack-list">
            {
              CAREER_STACK.map((item) => {
                const local = item[lang];
                return (
                  <div class="careers-stack-item card card--compact">
                    <dt class="careers-stack-label">{local.label}</dt>
                    <dd class="careers-stack-value">{local.value}</dd>
                  </div>
                );
              })
            }
          </dl>
        </div>

        <div class="careers-block">
          <p class="t-eyebrow-accent careers-block__title">{t.vacanciesTitle}</p>
          <ul class="careers-vacancies" role="list">
            {
              t.vacancies.map((v) => (
                <li
                  class="careers-vacancy-item card card--compact card--interactive state"
                  role="listitem"
                >
                  <span class="vacancy-type">{v.type}</span>
                  <span class="vacancy-title">{v.title}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div class="reveal-right">
        <div class="card card-accent-top careers-form-panel">
          <div class="careers-form-panel__header">
            <p class="t-eyebrow-accent" style="margin-bottom:6px;display:block">
              {t.formCardLabel}
            </p>
            <h3 class="careers-form-panel__title">{t.formCardTitle}</h3>
            <p class="t-body-sm" style="color:var(--c-secondary);line-height:1.7">
              {t.formCardDesc}
            </p>
          </div>

          <div class="careers-form-panel__divider" role="separator" aria-hidden="true"></div>

          <p class="t-eyebrow-accent careers-form-panel__checks-title">{t.checkItemsLabel}</p>
          <ul class="careers-checklist">
            {
              t.checkItems.map((item) => (
                <li class="careers-check-item">
                  <span aria-hidden="true" class="careers-check-icon">
                    <svg
                      width="8"
                      height="8"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="var(--c-orange)"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                  </span>
                  {item}
                </li>
              ))
            }
          </ul>

          <div class="careers-form-actions">
            <a
              href={formUrl}
              target={formUrl !== "#" ? "_blank" : undefined}
              rel={formUrl !== "#" ? "noopener noreferrer" : undefined}
              class="btn-filled"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
              </svg>
              {t.formBtnLabel}
            </a>

            <CareersFAQ t={t.faq} client:load />
          </div>

          <div class="careers-status-bar">
            <div class="pulse careers-status-bar__dot" aria-hidden="true"></div>
            <p class="t-body-sm" style="color:var(--c-tertiary)">{t.statusLabel}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

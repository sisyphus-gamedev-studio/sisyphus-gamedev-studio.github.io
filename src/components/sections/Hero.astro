---
import type { TranslationStructure, Project } from "../../types";
import { BRAND, UI, SIZES } from "../../config";
import { getHeroImage, nativeImageFallback } from "../../utils/images";

interface Props {
  t: TranslationStructure["hero"];
  projects: Project[];
  titlesCount: number;
}

const { t, projects, titlesCount } = Astro.props;
const featured = projects[0];
const concept = projects[1] ?? null;
const titleWords = t.title.split(" ");
const heroMainImg = getHeroImage("hero-main");
const heroCard1Img = getHeroImage("hero-card-1");
const progressPct = `${featured.progress ?? 0}%`;
---

<section id="home" class="min-h-screen flex flex-col justify-center relative overflow-hidden">
  <div
    class="relative max-w-7xl mx-auto w-full px-5 sm:px-8"
    style="padding-top:120px;padding-bottom:96px;z-index:2"
  >
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-7">
        <div class="anim d1" style="margin-bottom:22px">
          <div class="md-badge-primary md-badge" style="display:inline-flex;gap:7px">
            <span
              class="pulse"
              style="width:6px;height:6px;border-radius:50%;background:var(--c-orange);flex-shrink:0;align-self:center"
            ></span>
            <span style="font-size:10px;letter-spacing:1.5px">{t.badge}</span>
          </div>
        </div>

        <h1 class="t-display-lg anim d2" style="color:var(--c-on-surface)">
          {
            titleWords.map((word, i) => (
              <span
                class={i === titleWords.length - 1 ? "glitch-word" : undefined}
                data-text={i === titleWords.length - 1 ? word : undefined}
                style={`display:inline-block;color:${i === titleWords.length - 1 ? "var(--c-orange)" : "var(--c-on-surface)"};margin-right:${i < titleWords.length - 1 ? "0.2em" : "0"}`}
              >
                {word}
                {i === titleWords.length - 1 && (
                  <>
                    <span class="glitch-scanline" aria-hidden="true" />
                    <canvas class="glitch-noise" aria-hidden="true" />
                  </>
                )}
              </span>
            ))
          }
        </h1>

        <div class="anim d2" style="margin:18px 0"><div class="md-divider-accent"></div></div>

        <p
          class="t-body-lg anim d3"
          style="color:var(--c-secondary);max-width:440px;line-height:1.75;margin-bottom:36px"
        >
          {t.subtitle}
        </p>

        <div class="flex flex-wrap gap-3 anim d4" style="margin-bottom:52px">
          <a
            href="#projects"
            class="btn-filled"
            style="height:42px;padding-left:26px;padding-right:26px;font-size:14px"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><line x1="6" y1="11" x2="10" y2="11"></line><line x1="8" y1="9" x2="8" y2="13"
              ></line><line x1="15" y1="12" x2="15.01" y2="12"></line><line
                x1="18"
                y1="10"
                x2="18.01"
                y2="10"></line><path
                d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59 27.196 27.196 0 0 0 0 7.82A4 4 0 0 0 6.68 20h10.64a4 4 0 0 0 3.978-3.59 27.196 27.196 0 0 0 0-7.82A4 4 0 0 0 17.32 5z"
              ></path></svg
            >
            {t.cta}
          </a>
          <a href="#about" class="btn-outlined" style="height:42px;font-size:14px">
            {t.ctaSecondary}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
            >
          </a>
        </div>

        <div
          class="anim d5 stats-container"
          style="display:flex;align-items:center;gap:32px;margin-top:8px;flex-wrap:wrap"
        >
          {
            [
              { val: String(titlesCount), label: t.stats.titles },
              { val: String(BRAND.foundedYear), label: t.stats.founded },
              { val: UI.hero.stats.independent, label: t.stats.independent },
            ].map((s, i) => (
              <>
                <div style="display:flex;align-items:center;gap:12px" class="stat-card">
                  <div
                    class="t-stat-num"
                    style="font-size:42px;line-height:1;color:var(--c-orange)"
                  >
                    {s.val}
                  </div>
                  <div
                    class="t-label-sm"
                    style="color:var(--c-secondary);letter-spacing:.6px;font-size:11px;max-width:80px;line-height:1.3"
                  >
                    {s.label}
                  </div>
                </div>
                {i < 2 && (
                  <div
                    class="stat-dot"
                    style="width:4px;height:4px;border-radius:50%;background:var(--c-orange);opacity:.3;flex-shrink:0"
                  />
                )}
              </>
            ))
          }
        </div>
      </div>

      <div class="lg:col-span-5 anim d3">
        <a
          href={featured.wishlistUrl || "#"}
          target="_blank"
          rel="noopener noreferrer"
          class="card-game"
          aria-label={`${featured.title} — ${t.featuredLabel}`}
          style="display:block;text-decoration:none"
        >
          <img
            src={heroMainImg}
            alt={featured.title}
            width="720"
            height={String(SIZES.hero.cardHeight)}
            loading="eager"
            decoding="async"
            style={`width:100%;height:${SIZES.hero.cardHeight}px;object-fit:cover;display:block;filter:brightness(.4) saturate(.5)`}
            onerror={nativeImageFallback(720, 480)}
          />
          <div
            style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 30%,rgba(26,26,26,.97) 100%)"
          >
          </div>
          <div style="position:absolute;top:14px;right:14px">
            <div class="md-badge-primary md-badge" style="backdrop-filter:blur(8px);gap:5px">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="9"
                height="9"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"
                ></path></svg
              >
              {t.inDevLabel}
            </div>
          </div>
          <div style="padding:16px 20px 22px;position:relative">
            <p class="t-label-sm" style="color:var(--c-tertiary);margin-bottom:5px">
              {t.featuredLabel}
            </p>
            <h3 class="t-card-title" style="font-size:26px;margin-bottom:6px">{featured.title}</h3>
            <p class="t-body-sm" style="color:var(--c-tertiary);margin-bottom:14px">
              {t.featuredSub}
            </p>
            <div style="display:flex;align-items:center;gap:10px">
              <div class="md-progress-track" style="flex:1">
                <div class="md-progress-bar" style={`width:${progressPct}`}></div>
              </div>
              <span class="t-label-md" style="color:var(--c-orange);flex-shrink:0"
                >{progressPct}</span
              >
            </div>
            <p class="t-label-sm" style="color:var(--c-tertiary);margin-top:5px">
              {t.progressLabel}
            </p>
          </div>
        </a>

        {
          concept && (
            <a
              href={concept.wishlistUrl || "#"}
              target="_blank"
              rel="noopener noreferrer"
              class="card-filled"
              style="margin-top:8px;padding:14px 16px;display:flex;align-items:center;gap:14px;text-decoration:none"
              aria-label={concept.title}
            >
              <img
                src={heroCard1Img}
                alt={concept.title}
                width={String(SIZES.hero.cardImageSize)}
                height={String(SIZES.hero.cardImageSize)}
                loading="eager"
                decoding="async"
                style={`width:${SIZES.hero.cardImageSize}px;height:${SIZES.hero.cardImageSize}px;border-radius:10px;object-fit:cover;flex-shrink:0;filter:brightness(.35) saturate(.3)`}
                onerror={nativeImageFallback(200, 200)}
              />
              <div style="flex:1;min-width:0">
                <p class="t-label-sm" style="color:var(--c-tertiary);margin-bottom:2px">
                  {t.conceptLabel}
                </p>
                <p class="t-card-title" style="font-size:14px;margin-bottom:2px">
                  {concept.title}
                </p>
                <p class="t-body-sm" style="color:var(--c-tertiary);margin-top:1px">
                  {t.conceptSub}
                </p>
              </div>
              <div class="md-badge" style="flex-shrink:0">
                {t.comingSoon}
              </div>
            </a>
          )
        }
      </div>
    </div>
  </div>

  <div
    class="anim d6"
    style="position:absolute;bottom:22px;left:0;right:0;display:flex;flex-direction:column;align-items:center;gap:6px;z-index:2"
  >
    <span class="t-label-sm" style="color:var(--c-tertiary);letter-spacing:3px;opacity:.6"
      >{t.scroll}</span
    >
    <div
      style="width:1px;height:24px;background:linear-gradient(180deg,var(--c-tertiary) 0%,transparent 100%);opacity:.35"
    >
    </div>
  </div>
</section>

<style>
  .stat-card {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .stat-card .t-stat-num {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-block;
  }

  .stat-card:hover {
    opacity: 1;
  }

  .stat-card:hover .t-stat-num {
    transform: scale(1.08);
    color: var(--c-orange-light);
  }

  @media (max-width: 768px) {
    .stats-container {
      display: grid !important;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px !important;
      margin-top: 8px;
    }

    .stat-dot {
      display: none !important;
    }

    .stat-card {
      flex-direction: column !important;
      align-items: center !important;
      text-align: center;
      gap: 8px !important;
      padding: 16px 12px;
      background: rgba(255, 255, 255, 0.02);
      border-radius: 10px;
      border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .stat-card .t-stat-num {
      font-size: 32px !important;
    }

    .stat-card .t-label-sm {
      max-width: 100% !important;
      font-size: 9px !important;
      letter-spacing: 0.5px !important;
    }
  }

  @media (max-width: 480px) {
    .stats-container {
      grid-template-columns: 1fr !important;
      gap: 12px !important;
    }

    .stat-card {
      flex-direction: row !important;
      justify-content: flex-start !important;
      text-align: left !important;
      padding: 14px 16px;
    }

    .stat-card .t-stat-num {
      font-size: 36px !important;
    }

    .stat-card .t-label-sm {
      font-size: 10px !important;
      max-width: 120px !important;
    }
  }

  @media (hover: none) {
    .stat-card:hover .t-stat-num {
      transform: none;
    }
  }
</style>

<script>
  function initGlitch() {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const el = document.querySelector(".glitch-word") as HTMLElement | null;
    if (!el) return;

    const canvas = el.querySelector(".glitch-noise") as HTMLCanvasElement | null;
    const ctx = canvas?.getContext("2d") ?? null;
    let noiseRaf = 0;
    let noiseStop = 0;

    if (canvas && ctx) {
      const resize = () => {
        canvas.width = el.offsetWidth || 200;
        canvas.height = el.offsetHeight || 60;
      };
      resize();
      new ResizeObserver(resize).observe(el);
    }

    function drawNoise() {
      if (!ctx || !canvas) return;
      const img = ctx.createImageData(canvas.width, canvas.height);
      for (let i = 0; i < img.data.length; i += 4) {
        const on = Math.random() > 0.52;
        img.data[i] = img.data[i + 1] = img.data[i + 2] = on ? 255 : 0;
        img.data[i + 3] = on ? Math.floor(Math.random() * 160 + 60) : 0;
      }
      ctx.putImageData(img, 0, 0);
    }

    function startNoise(ms: number) {
      cancelAnimationFrame(noiseRaf);
      clearTimeout(noiseStop);
      function loop() {
        drawNoise();
        noiseRaf = requestAnimationFrame(loop);
      }
      loop();
      noiseStop = setTimeout(() => {
        cancelAnimationFrame(noiseRaf);
        if (ctx && canvas) ctx.clearRect(0, 0, canvas.width, canvas.height);
      }, ms) as unknown as number;
    }

    const dur = {
      "g-burst": 550,
      "g-echo": 380,
      "g-tick": 200,
      "g-drift": 900,
      "g-stutter": 140,
    } as const;
    type G = keyof typeof dur;

    let timer: ReturnType<typeof setTimeout>;

    function fire(type: G) {
      el!.classList.add(type);
      startNoise(dur[type]);
      setTimeout(() => el!.classList.remove(type), dur[type] + 20);
    }

    function delay(ms: number): Promise<void> {
      return new Promise((r) => {
        timer = setTimeout(r, ms);
      });
    }

    async function seqClassic() {
      fire("g-burst");
      await delay(dur["g-burst"] + 280 + Math.random() * 180);
      fire("g-echo");
      await delay(dur["g-echo"] + 520 + Math.random() * 380);
      fire("g-tick");
    }

    async function seqStutter() {
      const count = 3 + Math.floor(Math.random() * 3);
      for (let i = 0; i < count; i++) {
        fire("g-stutter");
        await delay(dur["g-stutter"] + 40 + Math.random() * 60);
      }
      await delay(120 + Math.random() * 80);
      fire("g-echo");
    }

    async function seqDrift() {
      fire("g-drift");
      await delay(dur["g-drift"] + 200 + Math.random() * 200);
      fire("g-tick");
    }

    async function seqCorrupt() {
      fire("g-burst");
      await delay(dur["g-burst"] + 900 + Math.random() * 600);
      fire("g-stutter");
      await delay(dur["g-stutter"] + 50 + Math.random() * 40);
      fire("g-stutter");
    }

    const sequences = [seqClassic, seqStutter, seqDrift, seqCorrupt];
    let lastSeq = -1;

    async function run() {
      let idx: number;
      do {
        idx = Math.floor(Math.random() * sequences.length);
      } while (idx === lastSeq);
      lastSeq = idx;
      await sequences[idx]();
      timer = setTimeout(run, 2200 + Math.random() * 2800);
    }

    timer = setTimeout(run, 1400 + Math.random() * 600);

    document.addEventListener(
      "astro:before-swap",
      () => {
        clearTimeout(timer);
        clearTimeout(noiseStop);
        cancelAnimationFrame(noiseRaf);
      },
      { once: true },
    );
  }

  document.addEventListener("astro:page-load", initGlitch);
</script>

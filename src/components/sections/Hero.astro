---
import type { TranslationStructure, Project } from "../../types";
import { BRAND, UI, SIZES, LAYOUT } from "../../config";
import { getHeroImage, nativeImageFallback } from "../../utils/images";

interface Props {
  t: TranslationStructure["hero"];
  projects: Project[];
  titlesCount: number;
}

const { t, projects, titlesCount } = Astro.props;
const featured = projects[0];
const concept = projects[1] ?? null;
const titleWords = t.title.split(" ");
const heroMainImg = getHeroImage("hero-main");
const heroCard1Img = getHeroImage("hero-card-1");
const progressPct = `${featured.progress ?? 0}%`;
---

<section id="home" class="min-h-screen flex flex-col justify-center relative overflow-hidden">
  <div
    class="hero-inner relative w-full"
    style={`box-sizing:border-box;max-width:${LAYOUT.maxWidth}px;margin-left:auto;margin-right:auto;padding-top:${SIZES.hero.paddingTop}px;padding-bottom:${SIZES.hero.paddingBottom}px;padding-left:calc(clamp(${LAYOUT.padding}px, 3vw + 14px, 44px) + env(safe-area-inset-left, 0px));padding-right:calc(clamp(${LAYOUT.padding}px, 3vw + 14px, 44px) + env(safe-area-inset-right, 0px))`}
  >
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-7">
        <div class="anim d1 hero-eyebrow-badge">
          <div class="md-badge-primary md-badge">
            <span class="pulse" aria-hidden="true"></span>
            <span class="hero-eyebrow-badge__label">{t.badge}</span>
          </div>
        </div>

        <h1 class="t-display-lg anim d2" style="color:var(--c-on-surface)">
          {
            titleWords.map((word, i) => (
              <span
                class={i === titleWords.length - 1 ? "glitch-word" : undefined}
                data-text={i === titleWords.length - 1 ? word : undefined}
                style={`display:inline-block;color:${i === titleWords.length - 1 ? "var(--c-orange)" : "var(--c-on-surface)"};margin-right:${i < titleWords.length - 1 ? "0.2em" : "0"}`}
              >
                {word}
                {i === titleWords.length - 1 && (
                  <>
                    <span class="glitch-scanline" aria-hidden="true" />
                    <canvas class="glitch-noise" aria-hidden="true" />
                  </>
                )}
              </span>
            ))
          }
        </h1>

        <div class="flex flex-wrap gap-3 anim d4" style="margin-top:48px;margin-bottom:52px">
          <a
            href="#projects"
            class="btn-filled"
            style="height:42px;padding-left:26px;padding-right:26px;font-size:14px"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><line x1="6" y1="11" x2="10" y2="11"></line><line x1="8" y1="9" x2="8" y2="13"
              ></line><line x1="15" y1="12" x2="15.01" y2="12"></line><line
                x1="18"
                y1="10"
                x2="18.01"
                y2="10"></line><path
                d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59 27.196 27.196 0 0 0 0 7.82A4 4 0 0 0 6.68 20h10.64a4 4 0 0 0 3.978-3.59 27.196 27.196 0 0 0 0-7.82A4 4 0 0 0 17.32 5z"
              ></path></svg
            >
            {t.cta}
          </a>
          <a href="#about" class="btn-outlined" style="height:42px;font-size:14px">
            {t.ctaSecondary}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
            >
          </a>
        </div>

        <div
          class="anim d5 stats-container"
          style="display:flex;align-items:center;gap:32px;margin-top:8px;flex-wrap:wrap"
        >
          {
            [
              { val: String(titlesCount), label: t.stats.titles },
              { val: String(BRAND.foundedYear), label: t.stats.founded },
              { val: UI.hero.stats.independent, label: t.stats.independent },
            ].map((s, i) => (
              <>
                <div style="display:flex;align-items:center;gap:12px" class="hero-stat">
                  <div
                    class="t-stat-num"
                    style={`font-size:${SIZES.hero.statNumSize}px;line-height:1;color:var(--c-orange)`}
                  >
                    {s.val}
                  </div>
                  <div
                    class="t-label-sm"
                    style="color:var(--c-secondary);letter-spacing:.6px;font-size:11px;max-width:80px;line-height:1.3"
                  >
                    {s.label}
                  </div>
                </div>
                {i < 2 && (
                  <div
                    class="stat-dot"
                    style="width:4px;height:4px;border-radius:50%;background:var(--c-orange);opacity:.3;flex-shrink:0"
                  />
                )}
              </>
            ))
          }
        </div>
      </div>

      <div class="lg:col-span-5 anim d3">
        <a
          href={featured.wishlistUrl || "#"}
          target="_blank"
          rel="noopener noreferrer"
          class="card card--media card--interactive"
          aria-label={featured.title}
          style="display:block;text-decoration:none"
        >
          <div class="project-media-frame">
            {
              featured.video ? (
                <video
                  src={featured.video}
                  poster={heroMainImg}
                  autoplay
                  loop
                  muted
                  playsinline
                  aria-label={featured.title}
                  class="hero-featured__video project-media-fit"
                />
              ) : (
                <img
                  src={heroMainImg}
                  alt={featured.title}
                  loading="eager"
                  decoding="async"
                  class="hero-featured__image project-media-fit"
                  onerror={nativeImageFallback(720, 480)}
                />
              )
            }
            <div class="hero-featured__overlay" aria-hidden="true"></div>
            <div class="hero-featured__badge-wrap">
              <div class="md-badge-primary md-badge hero-featured__badge">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="9"
                  height="9"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"
                  ></path></svg
                >
                {t.inDevLabel}
              </div>
            </div>
          </div>
          <div class="hero-featured__body">
            <h3 class="t-card-title hero-featured__title">{featured.title}</h3>
            <p class="t-body-sm hero-featured__sub">{t.featuredSub}</p>
            <div class="hero-featured__progress-row">
              <div class="md-progress-track md-progress-track--lg">
                <div class="md-progress-bar" style={`width:${progressPct}`}></div>
              </div>
              <span class="t-label-md hero-featured__progress-value">{progressPct}</span>
            </div>
            <p class="t-label-sm hero-featured__progress-label">{t.progressLabel}</p>
          </div>
        </a>

        {
          concept && (
            <a
              href={concept.wishlistUrl || "#"}
              target="_blank"
              rel="noopener noreferrer"
              class="card card--secondary card--interactive hero-concept-card"
              aria-label={concept.title}
            >
              <img
                src={heroCard1Img}
                alt={concept.title}
                width={String(SIZES.hero.cardImageSize)}
                height={String(SIZES.hero.cardImageSize)}
                loading="eager"
                decoding="async"
                class="hero-concept__thumb"
                onerror={nativeImageFallback(200, 200)}
              />
              <div class="hero-concept__body">
                <p class="t-card-title hero-concept__title">{concept.title}</p>
                <p class="t-body-sm hero-concept__sub">{t.conceptSub}</p>
              </div>
              <div class="md-badge hero-concept__badge">{t.comingSoon}</div>
            </a>
          )
        }
      </div>
    </div>
  </div>

  <div
    class="anim d6"
    style="position:absolute;bottom:22px;left:0;right:0;display:flex;flex-direction:column;align-items:center;gap:6px;z-index:2"
  >
    <span class="t-label-sm" style="color:var(--c-tertiary);letter-spacing:3px;opacity:.6"
      >{t.scroll}</span
    >
    <div
      style="width:1px;height:24px;background:linear-gradient(180deg,var(--c-tertiary) 0%,transparent 100%);opacity:.35"
    >
    </div>
  </div>
</section>

<style>
  .hero-stat {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero-stat .t-stat-num {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-block;
  }

  .hero-stat:hover {
    opacity: 1;
  }

  .hero-stat:hover .t-stat-num {
    transform: scale(1.08);
    color: var(--c-orange-light);
  }

  @media (max-width: 768px) {
    .stats-container {
      display: grid !important;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px !important;
      margin-top: 8px;
    }

    .stat-dot {
      display: none !important;
    }

    .hero-stat {
      flex-direction: column !important;
      align-items: center !important;
      text-align: center;
      gap: 8px !important;
      padding: 16px 12px;
      background: rgba(255, 255, 255, 0.02);
      border-radius: var(--r-md);
      border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .hero-stat .t-stat-num {
      font-size: 32px !important;
    }

    .hero-stat .t-label-sm {
      max-width: 100% !important;
      font-size: 9px !important;
      letter-spacing: 0.5px !important;
    }
  }

  @media (max-width: 480px) {
    .stats-container {
      grid-template-columns: 1fr !important;
      gap: 12px !important;
    }

    .hero-stat {
      flex-direction: row !important;
      justify-content: flex-start !important;
      text-align: left !important;
      padding: 14px 16px;
    }

    .hero-stat .t-stat-num {
      font-size: 36px !important;
    }

    .hero-stat .t-label-sm {
      font-size: 10px !important;
      max-width: 120px !important;
    }
  }

  @media (hover: none) {
    .hero-stat:hover .t-stat-num {
      transform: none;
    }
  }
</style>

<script>
  function initGlitch() {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const el = document.querySelector(".glitch-word") as HTMLElement | null;
    if (!el) return;

    const canvas = el.querySelector(".glitch-noise") as HTMLCanvasElement | null;
    const ctx = canvas?.getContext("2d") ?? null;
    let noiseRaf = 0;
    let noiseStop = 0;

    if (canvas && ctx) {
      const resize = () => {
        canvas.width = el.offsetWidth || 200;
        canvas.height = el.offsetHeight || 60;
      };
      resize();
      new ResizeObserver(resize).observe(el);
    }

    function drawNoise() {
      if (!ctx || !canvas) return;
      const img = ctx.createImageData(canvas.width, canvas.height);
      for (let i = 0; i < img.data.length; i += 4) {
        const on = Math.random() > 0.48;
        img.data[i] = on ? Math.floor(Math.random() * 255) : 0;
        img.data[i + 1] = on ? Math.floor(Math.random() * 80) : 0;
        img.data[i + 2] = on ? Math.floor(Math.random() * 255) : 0;
        img.data[i + 3] = on ? Math.floor(Math.random() * 180 + 75) : 0;
      }
      ctx.putImageData(img, 0, 0);
    }

    function startNoise(ms: number) {
      cancelAnimationFrame(noiseRaf);
      clearTimeout(noiseStop);
      function loop() {
        drawNoise();
        noiseRaf = requestAnimationFrame(loop);
      }
      loop();
      noiseStop = setTimeout(() => {
        cancelAnimationFrame(noiseRaf);
        if (ctx && canvas) ctx.clearRect(0, 0, canvas.width, canvas.height);
      }, ms) as unknown as number;
    }

    const dur = {
      "g-burst": 600,
      "g-echo": 420,
      "g-tick": 220,
      "g-drift": 1000,
      "g-stutter": 160,
      "g-shred": 750,
    } as const;
    type G = keyof typeof dur;

    let timer: ReturnType<typeof setTimeout>;

    function fire(type: G) {
      el!.classList.add(type);
      startNoise(dur[type]);
      setTimeout(() => el!.classList.remove(type), dur[type] + 20);
    }

    function delay(ms: number): Promise<void> {
      return new Promise((r) => {
        timer = setTimeout(r, ms);
      });
    }

    async function seqClassic() {
      fire("g-burst");
      await delay(dur["g-burst"] + 220 + Math.random() * 180);
      fire("g-echo");
      await delay(dur["g-echo"] + 420 + Math.random() * 300);
      fire("g-tick");
    }

    async function seqStutter() {
      const count = 4 + Math.floor(Math.random() * 4);
      for (let i = 0; i < count; i++) {
        fire("g-stutter");
        await delay(dur["g-stutter"] + 30 + Math.random() * 50);
      }
      await delay(80 + Math.random() * 60);
      fire("g-echo");
    }

    async function seqDrift() {
      fire("g-drift");
      await delay(dur["g-drift"] + 150 + Math.random() * 200);
      fire("g-tick");
    }

    async function seqCorrupt() {
      fire("g-burst");
      await delay(dur["g-burst"] + 700 + Math.random() * 500);
      fire("g-stutter");
      await delay(dur["g-stutter"] + 40 + Math.random() * 30);
      fire("g-stutter");
      await delay(dur["g-stutter"] + 60 + Math.random() * 40);
      fire("g-burst");
    }

    async function seqShred() {
      fire("g-shred");
      await delay(dur["g-shred"] + 300 + Math.random() * 250);
      fire("g-tick");
      await delay(dur["g-tick"] + 120 + Math.random() * 80);
      fire("g-echo");
    }

    async function seqDoubleShred() {
      fire("g-stutter");
      await delay(dur["g-stutter"] + 80);
      fire("g-shred");
      await delay(dur["g-shred"] + 500 + Math.random() * 300);
      fire("g-burst");
    }

    const sequences = [seqClassic, seqStutter, seqDrift, seqCorrupt, seqShred, seqDoubleShred];
    let lastSeq = -1;

    async function run() {
      let idx: number;
      do {
        idx = Math.floor(Math.random() * sequences.length);
      } while (idx === lastSeq);
      lastSeq = idx;
      await sequences[idx]();
      timer = setTimeout(run, 1800 + Math.random() * 2400);
    }

    timer = setTimeout(run, 1000 + Math.random() * 500);

    document.addEventListener(
      "astro:before-swap",
      () => {
        clearTimeout(timer);
        clearTimeout(noiseStop);
        cancelAnimationFrame(noiseRaf);
      },
      { once: true },
    );
  }

  document.addEventListener("astro:page-load", initGlitch);

  function initHeroVideo() {
    const video = document.querySelector(".hero-featured__video") as HTMLVideoElement | null;
    if (!video) return;

    const mq = window.matchMedia("(prefers-reduced-motion: reduce)");
    const apply = () => {
      if (mq.matches) {
        video.pause();
        video.style.display = "none";
      } else {
        video.style.display = "block";
        void video.play().catch(() => {});
      }
    };

    apply();
    mq.addEventListener("change", apply);
    document.addEventListener("astro:before-swap", () => mq.removeEventListener("change", apply), {
      once: true,
    });
  }

  document.addEventListener("astro:page-load", initHeroVideo);
</script>

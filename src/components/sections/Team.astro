---
import type { Language, TranslationStructure } from "../../types";
import TeamGrid from "../features/TeamGrid";

interface Props {
  t: TranslationStructure["team"];
  partnerLinkLabels: TranslationStructure["partners"]["linkLabels"];
  lang: Language;
}

const { t, lang, partnerLinkLabels } = Astro.props;
---

<section id="team" class="site-section site-section--grid" aria-labelledby="team-heading">
  <div class="site-section__container">
    <div class="site-section__head reveal">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-label">{t.sectionLabel}</span>
      </div>
      <h2 id="team-heading" class="t-display-md section-heading">
        {t.heading}<span class="section-heading__accent"> {t.headingSuffix}</span>
      </h2>
      <p class="t-body-lg section-lead" style="max-width:760px">{t.description}</p>
    </div>

    <div class="reveal">
      <TeamGrid
        t={t}
        lang={lang}
        partnerLinkLabels={partnerLinkLabels}
        client:visible
      />
    </div>
  </div>
</section>

---
import type { Language, TranslationStructure } from "../../types";
import { BRAND, IMAGES } from "../../config";
import { nativeImageFallback } from "../../utils/images";

interface Props {
  t: TranslationStructure["about"];
  lang: Language;
  titlesCount: number;
}

const { t, lang, titlesCount } = Astro.props;

const stats = [
  { value: String(BRAND.teamSize), label: t.stats.team },
  { value: String(titlesCount), label: t.stats.titles },
  { value: String(BRAND.foundedYear), label: t.stats.founded },
  { value: "∞", label: t.stats.enthusiasm },
];

const aboutImg = IMAGES.about;
---

<section
  id="about"
  class="site-section site-section--filled about-section"
  aria-labelledby="about-heading"
>
  <div class="site-section__container">
    <div class="about-section__head reveal">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-label">{t.sectionLabel}</span>
      </div>
      <h2 id="about-heading" class="t-display-md" style="color:var(--c-on-surface)">
        {t.heading}<span style="color:var(--c-orange)"> {t.headingSuffix}</span>
      </h2>
    </div>

    <div class="about-grid">
      <div class="about-column about-column--main reveal-left">
        <figure class="about-media about-img-wrap">
          <img
            src={aboutImg}
            alt="Studio workspace"
            width="700"
            height="400"
            loading="lazy"
            decoding="async"
            onerror={nativeImageFallback(700, 400)}
          />
          <div class="about-media__scrim" aria-hidden="true"></div>
          <figcaption class="about-media__meta">
            <div>
              <p class="t-label-sm about-media__founded-label">{t.foundedLabel}</p>
              <p class="t-display-sm about-media__founded-year">{String(BRAND.foundedYear)}</p>
            </div>
            <span class="about-media__badge">{t.indieLabel}</span>
          </figcaption>
        </figure>

        <div class="about-prose">
          {
            t.descriptionParagraphs.map((paragraph) => (
              <p class="t-body-lg about-prose__paragraph">{paragraph}</p>
            ))
          }
        </div>
      </div>

      <aside class="about-column about-column--aside reveal-right">
        <dl class="about-stats">
          {
            stats.map((s) => (
              <div class="about-stat state">
                <dd class="t-stat-num about-stat__value" aria-label={`${s.value} — ${s.label}`}>
                  {s.value}
                </dd>
                <dt class="t-body-sm about-stat__label">{s.label}</dt>
              </div>
            ))
          }
        </dl>

        <div class="content-panel about-mission">
          <p class="t-label-sm about-mission__label">{t.missionLabel}</p>
          <blockquote lang={lang} class="t-body-lg about-mission__quote">
            {t.missionQuote}
          </blockquote>
        </div>

        <div class="status-card about-status">
          <div class="pulse" style="width:8px;height:8px;border-radius:50%;background:var(--c-orange);flex-shrink:0" aria-hidden="true"></div>
          <div>
            <p class="t-title-sm about-status__title">{t.statusLabel}</p>
            <p class="t-body-sm about-status__sub">{t.statusSub}</p>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

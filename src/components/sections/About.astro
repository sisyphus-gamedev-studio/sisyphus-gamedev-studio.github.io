---
import DisciplineIcon from "../common/DisciplineIcon.astro";
import type { IconName } from "../common/DisciplineIcon.astro";
import type { Language, TranslationStructure } from "../../types";
import { BRAND, UI } from "../../config";

interface Props {
  t: TranslationStructure["about"];
  lang: Language;
  titlesCount: number;
}

const { t, lang, titlesCount } = Astro.props;

const stats = [
  { value: String(BRAND.teamSize), label: t.stats.team },
  { value: String(titlesCount), label: t.stats.titles },
  { value: String(BRAND.foundedYear), label: t.stats.founded },
  { value: UI.hero.stats.independent, label: t.stats.independent },
];

const disciplines: { label: string; icon: IconName }[] = [
  { label: t.disciplines.engineering, icon: "engineering" },
  { label: t.disciplines.art, icon: "art" },
  { label: t.disciplines.sound, icon: "sound" },
  { label: t.disciplines.design, icon: "design" },
];

const svgContent =
  '<svg xmlns="http://www.w3.org/2000/svg" width="700" height="400" viewBox="0 0 700 400"><rect width="700" height="400" fill="#1e1e1e"/><rect x="260" y="140" width="180" height="120" rx="14" fill="none" stroke="#2a2a2a" stroke-width="2"/><rect x="280" y="160" width="60" height="40" rx="6" fill="#252525"/><rect x="360" y="160" width="60" height="40" rx="6" fill="#252525"/><rect x="280" y="215" width="140" height="6" rx="3" fill="#252525"/><rect x="280" y="228" width="100" height="6" rx="3" fill="#242424"/><circle cx="350" cy="100" r="24" fill="none" stroke="#2a2a2a" stroke-width="2"/><line x1="350" y1="88" x2="350" y2="112" stroke="#2a2a2a" stroke-width="2" stroke-linecap="round"/><line x1="338" y1="100" x2="362" y2="100" stroke="#2a2a2a" stroke-width="2" stroke-linecap="round"/></svg>';
const workspaceImg = `data:image/svg+xml;charset=utf-8,${encodeURIComponent(svgContent)}`;
---

<section
  id="about"
  aria-labelledby="about-heading"
  style="padding:100px 0;border-top:1px solid var(--b-default);position:relative;overflow:hidden"
>
  <div style="max-width:1280px;margin:0 auto;padding:0 20px;position:relative;z-index:2">
    <div class="reveal" style="margin-bottom:56px">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-label">{t.sectionLabel}</span>
      </div>
      <h2 id="about-heading" class="t-display-md" style="color:var(--c-on-surface)">{t.heading}</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <div class="reveal-left">
        <div
          style="border-radius:20px;overflow:hidden;position:relative;height:272px;margin-bottom:28px;border:1px solid var(--b-default)"
        >
          <img
            src={workspaceImg}
            alt="Studio workspace"
            width="700"
            height="400"
            loading="lazy"
            decoding="async"
            style="width:100%;height:100%;object-fit:cover;display:block"
          />
          <div
            style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,26,26,.97) 100%)"
          >
          </div>
          <div
            style="position:absolute;bottom:0;left:0;right:0;padding:16px 20px;display:flex;align-items:flex-end;justify-content:space-between"
          >
            <div>
              <p class="t-label-sm" style="color:var(--c-tertiary)">{t.foundedLabel}</p>
              <p class="t-display-sm" style="color:var(--c-on-surface)">
                {String(BRAND.foundedYear)}
              </p>
            </div>
            <div
              style="padding:4px 12px;border-radius:var(--r-full);background:var(--c-orange-dim);border:1px solid var(--c-orange-border);color:var(--c-orange-accent);font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase"
            >
              {t.indieLabel}
            </div>
          </div>
        </div>

        <p class="t-body-lg" style="color:var(--c-secondary);line-height:1.75;margin-bottom:28px">
          {t.description}
        </p>

        <div>
          <p class="t-label-sm" style="color:var(--c-tertiary);margin-bottom:10px">
            {t.craftLabel}
          </p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px" role="list">
            {
              disciplines.map(({ icon, label }) => (
                <div
                  class="state"
                  role="listitem"
                  style="height:38px;padding:0 14px;display:flex;align-items:center;gap:10px;background:var(--s-5);border:1px solid var(--b-subtle);border-radius:8px;cursor:default;overflow:hidden"
                >
                  <DisciplineIcon icon={icon} />
                  <span class="t-label-lg" style="color:var(--c-secondary);font-size:13px">
                    {label}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <div class="reveal-right" style="display:flex;flex-direction:column;gap:8px">
        <dl style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
          {
            stats.map((s) => (
              <div
                class="state"
                style="padding:20px 18px;cursor:default;background:var(--s-5);border:1px solid var(--b-subtle);border-radius:16px;overflow:hidden;position:relative;display:flex;flex-direction:column"
              >
                <dd
                  class="t-stat-num"
                  style="font-size:40px"
                  aria-label={`${s.value} — ${s.label}`}
                >
                  {s.value}
                </dd>
                <dt class="t-body-sm" style="color:var(--c-tertiary);margin-top:6px">
                  {s.label}
                </dt>
              </div>
            ))
          }
        </dl>

        <div
          style="padding:22px 24px;border-radius:16px;background:var(--s-5);border:1px solid var(--b-subtle);border-left:2px solid var(--c-orange)"
        >
          <p class="t-label-sm" style="color:var(--c-orange);margin-bottom:12px">
            {t.missionLabel}
          </p>
          <blockquote
            lang={lang}
            class="t-body-lg"
            style="color:var(--c-on-surface);font-style:italic;line-height:1.65;font-weight:400;margin:0"
          >
            {t.missionQuote}
          </blockquote>
        </div>

        <div
          style="padding:14px 18px;display:flex;align-items:center;gap:12px;background:var(--s-5);border:1px solid var(--b-subtle);border-radius:12px"
        >
          <div
            class="pulse"
            style="width:8px;height:8px;border-radius:50%;background:var(--c-orange);flex-shrink:0"
            aria-hidden="true"
          >
          </div>
          <div>
            <p class="t-title-sm" style="color:var(--c-on-surface)">{t.statusLabel}</p>
            <p class="t-body-sm" style="color:var(--c-tertiary);margin-top:2px">{t.statusSub}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

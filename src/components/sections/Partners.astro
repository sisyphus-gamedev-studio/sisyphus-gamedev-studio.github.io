---
import type { TranslationStructure, Language } from "../../types";
import { PARTNERS, PARTNER_LOGO_STYLES, PARTNER_CATEGORY_STYLES } from "../../config/partners";
import { SOCIAL_ICONS } from "../../config";

interface Props {
  t: NonNullable<TranslationStructure["partners"]>;
  lang: Language;
}

const { t, lang } = Astro.props;
---

<section id="partners" class="site-section site-section--filled" aria-labelledby="partners-heading">
  <div class="site-section__container">
    <div class="site-section__head site-section__head--row reveal">
      <div>
        <div class="section-eyebrow">
          <div class="section-eyebrow-line"></div>
          <span class="section-eyebrow-label">{t.sectionLabel}</span>
        </div>
        <h2 id="partners-heading" class="t-display-md section-heading">
          {t.heading}<span class="section-heading__accent"> {t.headingSuffix}</span>
        </h2>
        <p class="t-body-lg section-lead section-lead--wide">{t.description}</p>
      </div>
      <div class="section-status-badge">
        <span class="pulse section-status-badge__dot" aria-hidden="true"></span>
        {t.activeCount}
      </div>
    </div>

    <div class="reveal partners-grid" role="list" aria-label={t.sectionLabel}>
      {
        PARTNERS.map((partner) => {
          const localData = partner[lang];
          const isFeatured = !!partner.featured;
          const catLabel = t.categoryLabels[partner.category];
          const catStyle = PARTNER_CATEGORY_STYLES[partner.category];
          const logoStyle = PARTNER_LOGO_STYLES[partner.logoStyle] ?? PARTNER_LOGO_STYLES.orange;

          return (
            <div
              role="listitem"
              class={`card card--interactive state partner-card${isFeatured ? " card--accent" : ""}`}
              tabindex="0"
            >
              <div class="partner-card__inner">
                <div class="card-entity__header">
                  <div
                    class={`card-entity__media${partner.logoImage ? " card-entity__media--image" : ""}`}
                    style={partner.logoImage ? undefined : logoStyle}
                  >
                    {partner.logoImage ? (
                      <img
                        src={partner.logoImage}
                        alt={localData.name}
                        width="64"
                        height="64"
                        style="width:100%;height:100%;object-fit:cover"
                      />
                    ) : (
                      <span aria-hidden="true">{partner.logoInitials}</span>
                    )}
                  </div>
                  <div class="card-entity__body">
                    <h3 class="card-entity__title t-card-title">{localData.name}</h3>
                    <span
                      class="md-badge"
                      style={`${catStyle}`}
                    >
                      {catLabel}
                    </span>
                  </div>
                </div>

                <p class="t-body-sm card-entity__desc">{localData.description}</p>

                <div class="partner-card__links">
                  {partner.links.website && partner.links.website !== "#" && (
                    <a
                      href={partner.links.website}
                      target="_blank"
                      rel="noopener noreferrer"
                      class={isFeatured ? "btn-tonal" : "btn-outlined"}
                      aria-label={`${localData.name} — ${t.linkLabels.website}`}
                    >
                      <svg
                        width="11"
                        height="11"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.2"
                        stroke-linecap="round"
                        aria-hidden="true"
                      >
                        <circle cx="12" cy="12" r="10" />
                        <line x1="2" y1="12" x2="22" y2="12" />
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                      </svg>
                      {t.linkLabels.website}
                    </a>
                  )}
                  {partner.links.steam && partner.links.steam !== "#" && (
                    <a
                      href={partner.links.steam}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn-outlined"
                      aria-label={`${localData.name} — ${t.linkLabels.steam}`}
                    >
                      <Fragment set:html={SOCIAL_ICONS.steamSm} />
                      {t.linkLabels.steam}
                    </a>
                  )}
                  {partner.links.twitter && partner.links.twitter !== "#" && (
                    <a
                      href={partner.links.twitter}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn-outlined"
                      aria-label={`${localData.name} — ${t.linkLabels.twitter}`}
                    >
                      <svg
                        width="11"
                        height="11"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.2"
                        stroke-linecap="round"
                        aria-hidden="true"
                      >
                        <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z" />
                      </svg>
                      {t.linkLabels.twitter}
                    </a>
                  )}
                  {partner.links.github && partner.links.github !== "#" && (
                    <a
                      href={partner.links.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn-outlined"
                      aria-label={`${localData.name} — ${t.linkLabels.github}`}
                    >
                      <svg
                        width="11"
                        height="11"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.2"
                        stroke-linecap="round"
                        aria-hidden="true"
                      >
                        <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                      </svg>
                      {t.linkLabels.github}
                    </a>
                  )}
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

---
import type { TranslationStructure, Language } from "../../types";
import { PARTNERS, PARTNER_LOGO_STYLES, PARTNER_CATEGORY_STYLES } from "../../config/partners";
import { LAYOUT, SOCIAL_ICONS, OVERLAY } from "../../config";

interface Props {
  t: NonNullable<TranslationStructure["partners"]>;
  lang: Language;
}

const { t, lang } = Astro.props;
---

<section
  id="partners"
  aria-labelledby="partners-heading"
  style="padding:var(--spacing-section);background:transparent;border-top:1px solid var(--b-default);position:relative"
>
  <div
    style={`max-width:${LAYOUT.maxWidth}px;margin:0 auto;padding:0 ${LAYOUT.padding}px;position:relative;z-index:1`}
  >
    <div
      class="reveal"
      style="display:flex;align-items:flex-end;justify-content:space-between;gap:24px;flex-wrap:wrap;margin-bottom:52px"
    >
      <div>
        <div class="section-eyebrow">
          <div class="section-eyebrow-line"></div>
          <span class="section-eyebrow-label">{t.sectionLabel}</span>
        </div>
        <h2 id="partners-heading" class="t-display-md" style="color:var(--c-on-surface)">
          {t.heading}<span style="color:var(--c-orange)"> {t.headingSuffix}</span>
        </h2>
        <p
          class="t-body-lg"
          style="color:var(--c-secondary);max-width:460px;line-height:1.75;margin-top:14px"
        >
          {t.description}
        </p>
      </div>
      <div
        style="display:inline-flex;align-items:center;gap:7px;padding:6px 14px;border-radius:var(--r-full);font-size:11px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;border:1px solid var(--b-default);background:var(--s-5);color:var(--c-secondary)"
      >
        <span
          class="pulse"
          aria-hidden="true"
          style="width:6px;height:6px;border-radius:50%;background:var(--c-orange);flex-shrink:0;display:inline-block"
        ></span>
        {t.activeCount}
      </div>
    </div>

    <div
      class="reveal partners-grid"
      style="display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-bottom:40px"
      role="list"
      aria-label={t.sectionLabel}
    >
      {
        PARTNERS.map((partner) => {
          const localData = partner[lang];
          const isFeatured = !!partner.featured;
          const catLabel = t.categoryLabels[partner.category];
          const catStyle = PARTNER_CATEGORY_STYLES[partner.category];
          const logoStyle = PARTNER_LOGO_STYLES[partner.logoStyle] ?? PARTNER_LOGO_STYLES.orange;

          return (
            <div
              role="listitem"
              class="state"
              style={`background:var(--s-4);border:1px solid ${isFeatured ? "var(--c-orange-border)" : "var(--b-subtle)"};border-radius:var(--r-2xl);padding:28px;display:flex;flex-direction:column;position:relative;overflow:hidden;transition:border-color .25s,transform .3s var(--ease-em),box-shadow .3s`}
              tabindex="0"
            >
              <div style="position:relative;z-index:1;display:flex;flex-direction:column;height:100%">
                <div
                  style={`width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;margin-bottom:18px;font-size:17px;font-weight:900;letter-spacing:-1px;flex-shrink:0;${logoStyle}`}
                  aria-hidden="true"
                >
                  {partner.logoInitials}
                </div>

                <span
                  style={`display:inline-flex;align-items:center;padding:3px 10px;border-radius:var(--r-full);font-size:10px;font-weight:700;letter-spacing:.7px;text-transform:uppercase;background:${OVERLAY.tagBg};border:1px solid var(--b-subtle);color:var(--c-tertiary);margin-bottom:10px;width:fit-content;${catStyle}`}
                >
                  {catLabel}
                </span>

                <h3 style="font-size:20px;font-weight:800;color:var(--c-on-surface);text-transform:uppercase;letter-spacing:-.2px;margin-bottom:8px;line-height:1">
                  {localData.name}
                </h3>

                <p
                  class="t-body-sm"
                  style="color:var(--c-secondary);line-height:1.68;flex:1;margin-bottom:20px"
                >
                  {localData.description}
                </p>

                <div style="display:flex;gap:7px;flex-wrap:wrap;margin-top:auto">
                  {partner.links.website && partner.links.website !== "#" && (
                    <a
                      href={partner.links.website}
                      target="_blank"
                      rel="noopener noreferrer"
                      class={isFeatured ? "btn-tonal" : "btn-outlined"}
                      style="height:32px;padding:0 13px;font-size:11px;gap:5px"
                      aria-label={`${localData.name} — ${t.linkLabels.website}`}
                    >
                      <svg
                        width="11"
                        height="11"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.2"
                        stroke-linecap="round"
                        aria-hidden="true"
                      >
                        <circle cx="12" cy="12" r="10" />
                        <line x1="2" y1="12" x2="22" y2="12" />
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                      </svg>
                      {t.linkLabels.website}
                    </a>
                  )}
                  {partner.links.steam && partner.links.steam !== "#" && (
                    <a
                      href={partner.links.steam}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn-outlined"
                      style="height:32px;padding:0 13px;font-size:11px;gap:5px"
                      aria-label={`${localData.name} — ${t.linkLabels.steam}`}
                    >
                      <Fragment set:html={SOCIAL_ICONS.steamSm} />
                      {t.linkLabels.steam}
                    </a>
                  )}
                  {partner.links.twitter && partner.links.twitter !== "#" && (
                    <a
                      href={partner.links.twitter}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn-outlined"
                      style="height:32px;padding:0 13px;font-size:11px;gap:5px"
                      aria-label={`${localData.name} — ${t.linkLabels.twitter}`}
                    >
                      <svg
                        width="11"
                        height="11"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.2"
                        stroke-linecap="round"
                        aria-hidden="true"
                      >
                        <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z" />
                      </svg>
                      {t.linkLabels.twitter}
                    </a>
                  )}
                  {partner.links.github && partner.links.github !== "#" && (
                    <a
                      href={partner.links.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn-outlined"
                      style="height:32px;padding:0 13px;font-size:11px;gap:5px"
                      aria-label={`${localData.name} — ${t.linkLabels.github}`}
                    >
                      <svg
                        width="11"
                        height="11"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.2"
                        stroke-linecap="round"
                        aria-hidden="true"
                      >
                        <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                      </svg>
                      {t.linkLabels.github}
                    </a>
                  )}
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  #partners .state {
    cursor: default;
  }
  #partners .state:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 38px rgba(0, 0, 0, 0.5);
  }
  #partners .state:focus-visible {
    outline: 2px solid var(--c-orange);
    outline-offset: 2px;
  }

  @media (max-width: 680px) {
    #partners .partners-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>

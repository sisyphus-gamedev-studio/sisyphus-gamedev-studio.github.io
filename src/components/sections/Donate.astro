---
import type { TranslationStructure } from "../../types";
import { URLS, CONTACT } from "../../config";
import { isMailtoLink } from "../../utils/helpers";

interface Props {
  t: TranslationStructure["footer"]["cta"];
}

const { t } = Astro.props;
const donateUrl = URLS.donate;
const isMailto = isMailtoLink(donateUrl);

const TIER_ICONS = [
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="12" x2="10" y2="12"/><line x1="8" y1="10" x2="8" y2="14"/><circle cx="15.5" cy="12.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.01.15v.01a4 4 0 0 0 4 4.25h.01a4 4 0 0 0 3.97-3.59A4 4 0 0 0 14.63 13h.01a4 4 0 0 0 4-4.25v-.01c0-.05-.004-.1-.01-.15A4 4 0 0 0 17.32 5z"/></svg>`,
];

const TIER_HREFS = [`mailto:${CONTACT.email}`, donateUrl, URLS.steam];
const TIER_TARGETS = [undefined, isMailto ? undefined : "_blank", "_blank"];
const TIER_RELS = [undefined, isMailto ? undefined : "noopener noreferrer", "noopener noreferrer"];
---

<section
  id="donate"
  aria-labelledby="donate-heading"
  style="padding: var(--spacing-section); border-top: 1px solid var(--b-default); position: relative; overflow: hidden"
>
  <div style="max-width: 1280px; margin: 0 auto; padding: 0 20px; position: relative; z-index: 2">
    <div class="reveal donate-header">
      <div>
        <div class="section-eyebrow" style="margin-bottom: 16px">
          <div class="section-eyebrow-line"></div>
          <span class="section-eyebrow-label">{t.sectionLabel}</span>
        </div>
        <h2 id="donate-heading" class="t-display-md donate-title">
          {t.title}
          <span class="donate-title-accent">{t.titleSuffix}</span>
        </h2>
        <div class="md-divider-accent" style="margin-bottom: 16px"></div>
        <p class="t-body-lg donate-description">{t.description}</p>
      </div>

      <div class="donate-badge">
        <div class="pulse donate-badge-dot" aria-hidden="true"></div>
        <span class="t-label-sm donate-badge-text">{t.badge}</span>
      </div>
    </div>

    <div class="donate-tiers-grid">
      {
        t.tiers.map((tier, i) => (
          <a
            href={TIER_HREFS[i]}
            target={TIER_TARGETS[i]}
            rel={TIER_RELS[i]}
            class={`reveal-scale state donate-tier-card${i === 1 ? " donate-tier-card--highlight" : ""}`}
            style={`transition-delay: ${i * 0.1}s`}
          >
            <div class="donate-tier-icon" aria-hidden="true" set:html={TIER_ICONS[i]} />
            <div class="donate-tier-label">{tier.label}</div>
            <p class="t-title-sm donate-tier-title">{tier.title}</p>
            <p class="t-body-sm donate-tier-desc">{tier.description}</p>
            <div class="donate-tier-cta">
              {tier.cta}
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <>
                  <path d="M7 7h10v10" />
                  <path d="M7 17 17 7" />
                </>
              </svg>
            </div>
          </a>
        ))
      }
    </div>

    <p class="reveal t-body-sm donate-note">{t.note}</p>
  </div>
</section>

<style>
  .donate-header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 48px;
  }

  .donate-title {
    color: var(--c-on-surface);
    margin-bottom: 14px;
    line-height: 1;
  }
  .donate-title-accent {
    color: var(--c-orange);
  }

  .donate-description {
    color: var(--c-secondary);
    line-height: 1.75;
    max-width: 480px;
  }

  .donate-badge {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 18px;
    border-radius: var(--r-full);
    background: var(--s-5);
    border: 1px solid var(--b-subtle);
  }
  .donate-badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--c-orange);
    flex-shrink: 0;
  }
  .donate-badge-text {
    color: var(--c-secondary);
    font-size: 12px;
    letter-spacing: 0.5px;
  }

  .donate-tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 32px;
  }

  .donate-tier-card {
    display: flex;
    flex-direction: column;
    padding: 28px 24px;
    border-radius: 20px;
    border: 1px solid var(--b-subtle);
    background: var(--s-5);
    text-decoration: none;
    transition:
      border-color 0.2s,
      transform 0.2s var(--ease-em),
      box-shadow 0.2s;
  }
  .donate-tier-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
  }
  .donate-tier-card--highlight {
    border-color: var(--c-orange-border);
    background: color-mix(in srgb, var(--s-5) 95%, rgba(248, 126, 15, 1) 5%);
  }
  .donate-tier-card--highlight:hover {
    border-color: rgba(248, 126, 15, 0.4);
    box-shadow: 0 12px 32px rgba(248, 126, 15, 0.12);
  }

  .donate-tier-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--b-subtle);
    color: var(--c-secondary);
  }
  .donate-tier-card--highlight .donate-tier-icon {
    background: var(--c-orange-dim);
    border-color: var(--c-orange-border);
    color: var(--c-orange);
  }

  .donate-tier-label {
    display: inline-flex;
    align-items: center;
    height: 22px;
    padding: 0 10px;
    border-radius: var(--r-full);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 10px;
    width: fit-content;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--b-subtle);
    color: var(--c-tertiary);
  }
  .donate-tier-card--highlight .donate-tier-label {
    background: var(--c-orange-dim);
    border-color: var(--c-orange-border);
    color: var(--c-orange-accent);
  }

  .donate-tier-title {
    color: var(--c-on-surface);
    margin-bottom: 10px;
    font-size: 17px;
  }

  .donate-tier-desc {
    color: var(--c-secondary);
    line-height: 1.65;
    flex: 1;
    margin-bottom: 24px;
  }

  .donate-tier-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--c-secondary);
  }
  .donate-tier-card--highlight .donate-tier-cta {
    color: var(--c-orange);
  }

  .donate-note {
    color: var(--c-tertiary);
    text-align: center;
  }

  @media (max-width: 768px) {
    .donate-tiers-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .donate-tiers-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

---
import type { TranslationStructure } from "../../types";
import ContactForm from "../features/ContactForm";
import { CONTACT, CONTACT_PAGE_SOCIAL, SOCIAL_ICONS } from "../../config";

interface Props {
  t: TranslationStructure["contact"];
}

const { t } = Astro.props;

const contactInfo = [{ icon: SOCIAL_ICONS.email, text: CONTACT.contactEmail }];
---

<section id="contact" class="site-section site-section--grid" aria-labelledby="contact-heading">
  <div class="site-section__container">
    <div class="site-section__head reveal">
      <div class="section-eyebrow">
        <div class="section-eyebrow-line"></div>
        <span class="section-eyebrow-label">{t.sectionLabel}</span>
      </div>
      <h2 id="contact-heading" class="t-display-md section-heading">
        {t.heading}
        <span class="section-heading__accent">{t.headingSuffix}</span>
      </h2>
    </div>

    <div class="contact-layout">
      <div class="reveal reveal-left contact-sidebar">
        <p class="t-body-md section-lead section-lead--narrow contact-sidebar__lead">{t.description}</p>

        <div class="contact-info-list">
          {
            contactInfo.map((item) => (
              <div class="contact-info-row">
                <div class="contact-info-icon" set:html={item.icon} />
                <span class="t-body-sm" style="color:var(--c-tertiary)">{item.text}</span>
              </div>
            ))
          }
        </div>

        <div class="contact-social-row">
          {
            CONTACT_PAGE_SOCIAL.map((social) => (
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.label}
                class="footer-social-link state contact-social-link"
              >
                <Fragment set:html={social.iconSvg} />
                <span class="contact-social-link__label">{social.label}</span>
              </a>
            ))
          }
        </div>
      </div>

      <div class="reveal-right card card--flush contact-form-panel card-accent-top card-accent-top--contact">
        <div class="contact-form-panel__body">
          <ContactForm t={t} client:load />
        </div>
      </div>
    </div>
  </div>
</section>

---
import "../styles/global.css";
import { ViewTransitions } from "astro:transitions";
import { URLS, SEO, UI, BRAND } from "../config";

interface Props {
  lang: "en" | "ru";
  title?: string;
  description?: string;
  year: number;
}

const { lang, title = SEO.defaultTitle, description = SEO.defaultDescription } = Astro.props;

const otherLang = lang === "en" ? "ru" : "en";
const canonicalBase = URLS.site;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      name: `${BRAND.prefix} ${BRAND.suffix}`,
      url: canonicalBase,
      logo: `${canonicalBase}${SEO.ogImagePath}`,
      foundingDate: String(BRAND.foundedYear),
      description: SEO.defaultDescription,
      sameAs: [URLS.steam],
    },
    ...SEO.games.map((game) => ({
      "@type": "VideoGame",
      name: game.name,
      description: game.description,
      author: { "@type": "Organization", name: `${BRAND.prefix} ${BRAND.suffix}` },
      applicationCategory: "Game",
      operatingSystem: "Windows",
    })),
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={SEO.themeColor} media="(prefers-color-scheme: dark)" />
    <meta name="author" content={`${BRAND.prefix} ${BRAND.suffix}`} />
    <meta name="robots" content="index, follow" />

    <link rel="canonical" href={`${canonicalBase}/${lang}/`} />
    <link rel="alternate" hreflang={lang} href={`${canonicalBase}/${lang}/`} />
    <link rel="alternate" hreflang={otherLang} href={`${canonicalBase}/${otherLang}/`} />
    <link rel="alternate" hreflang="x-default" href={`${canonicalBase}/en/`} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={lang === "ru"
        ? `${BRAND.prefix} ${BRAND.suffix} — Новости`
        : `${BRAND.prefix} ${BRAND.suffix} — News`}
      href={`${canonicalBase}/${lang}/rss.xml`}
    />

    <link rel="dns-prefetch" href={URLS.steam} />
    <link rel="dns-prefetch" href="https://www.youtube.com" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${canonicalBase}${SEO.ogImagePath}`} />
    <meta property="og:image:width" content={String(SEO.ogImageWidth)} />
    <meta property="og:image:height" content={String(SEO.ogImageHeight)} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:url" content={`${canonicalBase}/${lang}/`} />
    <meta property="og:locale" content={lang === "ru" ? "ru_RU" : "en_US"} />
    <meta property="og:locale:alternate" content={lang === "ru" ? "en_US" : "ru_RU"} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${canonicalBase}${SEO.ogImagePath}`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Exo+2:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet" />

    <link rel="icon" type="image/png" href="/favicon.png" />

    <link rel="preload" as="image" href="/images/hero/hero-main.jpg" fetchpriority="high" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <script is:inline>
      (function () {
        var STORAGE_KEY = "ss_lang";
        var SUPPORTED = ["en", "ru"];
        try {
          var stored = localStorage.getItem(STORAGE_KEY);
          if (!stored || !SUPPORTED.includes(stored)) return;
          var parts = window.location.pathname.split("/").filter(Boolean);
          var pathLang = parts[0];
          if (pathLang === stored) return;
          if (SUPPORTED.includes(pathLang)) {
            parts[0] = stored;
            window.location.replace("/" + parts.join("/") + window.location.search);
          }
        } catch {
          void 0;
        }
      })();
    </script>

    <ViewTransitions />
  </head>
  <body>
    <a href="#main-content" class="skip-link">
      {UI.skipLink[lang]}
    </a>
    <noscript>
      <div
        style="position:fixed;bottom:0;left:0;right:0;z-index:1000;background:#1a1a1a;border-top:1px solid rgba(248,126,15,.3);padding:12px 20px;display:flex;align-items:center;justify-content:center;gap:10px;font-family:'Exo 2',sans-serif;font-size:13px;color:#999;"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#f87e0f"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line
            x1="12"
            y1="16"
            x2="12.01"
            y2="16"></line></svg
        >
        <span>{UI.noScript[lang]}</span>
      </div>
    </noscript>

    <div id="main-content">
      <slot />
    </div>

    <script>
      function initPage() {
        const existing = document.querySelector(".scroll-progress");
        if (existing) existing.remove();
        const bar = document.createElement("div");
        bar.className = "scroll-progress";
        document.body.prepend(bar);
        window.addEventListener(
          "scroll",
          () => {
            const pct =
              (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
            bar.style.width = Math.min(pct, 100) + "%";
          },
          { passive: true },
        );

        document.addEventListener("click", (e) => {
          const btn = (e.target as Element).closest(".btn-filled,.btn-tonal,.btn-outlined");
          if (!btn) return;
          const r = btn.getBoundingClientRect();
          const sz = Math.max(r.width, r.height) * 1.4;
          const w = document.createElement("span");
          w.className = "ripple-wave";
          w.style.cssText = `width:${sz}px;height:${sz}px;left:${e.clientX - r.left - sz / 2}px;top:${e.clientY - r.top - sz / 2}px;`;
          btn.appendChild(w);
          w.addEventListener("animationend", () => w.remove());
        });

        const obs = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("in");
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: "0px 0px -20% 0px" },
        );

        function observeRevealEls() {
          document
            .querySelectorAll(".reveal,.reveal-left,.reveal-right,.reveal-scale")
            .forEach((el) => {
              if (!el.classList.contains("in") && !(el as Element).hasAttribute("data-observed")) {
                (el as Element).setAttribute("data-observed", "1");
                obs.observe(el);
              }
            });
        }

        observeRevealEls();

        const mo = new MutationObserver(() => observeRevealEls());
        mo.observe(document.body, { childList: true, subtree: true });
      }

      document.addEventListener("astro:page-load", initPage);

      let savedScrollY = 0;
      document.addEventListener("astro:before-swap", () => {
        savedScrollY = window.scrollY;
      });
      document.addEventListener("astro:after-swap", () => {
        history.replaceState(null, "", window.location.pathname);
        requestAnimationFrame(() =>
          requestAnimationFrame(() => window.scrollTo({ top: savedScrollY, behavior: "instant" })),
        );
      });
    </script>
  </body>
</html>

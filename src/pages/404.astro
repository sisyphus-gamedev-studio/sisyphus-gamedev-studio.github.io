---
import "../styles/global.css";
import { TRANSLATIONS } from "../i18n/translations";
import { BRAND, FONTS } from "../config";
import type { Language } from "../types";

const urlPath = Astro.url.pathname;
const langFromUrl = urlPath.match(/^\/(ru|en)\//)?.[1] as Language | undefined;
const lang: Language = langFromUrl || "en";
const t = TRANSLATIONS[lang].notFound;
const ctaHref = `/${lang}/`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{t.badge} — {BRAND.prefix} {BRAND.suffix}</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={FONTS.googleCssHref} rel="stylesheet" />
  </head>
  <body class="not-found-page">
    <div class="not-found-glow" aria-hidden="true">
      <div class="not-found-glow__orb"></div>
    </div>
    <div class="not-found-content">
      <div class="md-badge-primary md-badge" style="display:inline-flex;margin-bottom:28px">
        <span class="section-status-badge__dot pulse" aria-hidden="true"></span>
        {t.badge}
      </div>
      <div class="not-found-code">
        4<span class="section-heading__accent">0</span>4
      </div>
      <h1 class="t-display-md section-heading" style="margin-bottom:16px;line-height:1.1">
        {t.title}
      </h1>
      <div class="not-found-divider" aria-hidden="true"></div>
      <p class="not-found-subtitle">{t.subtitle}</p>
      <a href={ctaHref} class="btn-404">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
        >
        {t.cta}
      </a>
      <div class="not-found-brand">
        <img
          src="/favicon.png"
          alt={`${BRAND.prefix} ${BRAND.suffix}`}
          class="not-found-brand__logo"
        />
        <span class="not-found-brand__text">
          {BRAND.prefix}<span class="section-heading__accent">{BRAND.suffix}</span>
        </span>
      </div>
    </div>
  </body>
</html>

---
import "../styles/global.css";
import { TRANSLATIONS } from "../i18n/translations";
import type { Language } from "../types";

const urlPath = Astro.url.pathname;
const langFromUrl = urlPath.match(/^\/(ru|en)\//)?.[1] as Language | undefined;
const lang: Language = langFromUrl || "en";
const t = TRANSLATIONS[lang].notFound;
const ctaHref = `/${lang}/`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{t.badge} — Sisyphus Studio</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Exo+2:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    style="background:var(--s-4);display:flex;align-items:center;justify-content:center;min-height:100vh;padding:20px"
  >
    <div style="text-align:center;max-width:480px">
      <div style="position:fixed;inset:0;pointer-events:none;overflow:hidden;z-index:0">
        <div
          style="position:absolute;border-radius:50%;filter:blur(120px);width:320px;height:320px;top:30%;left:50%;transform:translateX(-50%);background:radial-gradient(circle,rgba(248,126,15,.06) 0%,transparent 70%)"
        >
        </div>
      </div>
      <div style="position:relative;z-index:1">
        <div
          style="display:inline-flex;align-items:center;gap:7px;padding:4px 12px;border-radius:var(--r-full);background:var(--c-orange-dim);border:1px solid var(--c-orange-border);color:var(--c-orange-accent);font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:28px"
        >
          <span
            style="width:6px;height:6px;border-radius:50%;background:var(--c-orange);flex-shrink:0"
          ></span>
          {t.badge}
        </div>
        <div
          style="font-family:'Exo 2',sans-serif;font-size:clamp(80px,20vw,140px);font-weight:800;line-height:1;color:var(--c-on-surface);letter-spacing:-4px;margin-bottom:8px"
        >
          4<span style="color:var(--c-orange)">0</span>4
        </div>
        <h1
          style="font-family:'Exo 2',sans-serif;font-size:clamp(22px,4vw,32px);font-weight:700;text-transform:uppercase;color:var(--c-on-surface);margin-bottom:16px;line-height:1.1"
        >
          {t.title}
        </h1>
        <div
          style="width:36px;height:2px;background:linear-gradient(90deg,var(--c-orange),transparent);border-radius:var(--r-full);margin:0 auto 20px"
        >
        </div>
        <p
          style="font-family:'Exo 2',sans-serif;font-size:15px;color:var(--c-tertiary);line-height:1.7;margin-bottom:36px"
        >
          {t.subtitle}
        </p>
        <a href={ctaHref} class="btn-404">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
          >
          {t.cta}
        </a>
        <div
          style="margin-top:48px;display:flex;align-items:center;justify-content:center;gap:8px;opacity:.35"
        >
          <img
            src="/favicon.png"
            alt="Sisyphus Studio"
            style="width:22px;height:22px;border-radius:5px;object-fit:cover"
          />
          <span
            style="font-family:'Exo 2',sans-serif;font-size:15px;font-weight:700;color:var(--c-on-surface)"
          >
            Sisyphus<span style="color:var(--c-orange)">Studio</span>
          </span>
        </div>
      </div>
    </div>
  </body>
</html>

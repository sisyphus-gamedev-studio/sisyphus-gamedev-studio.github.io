---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/sections/Hero.astro";
import About from "../../components/sections/About.astro";
import Partners from "../../components/sections/Partners.astro";
import Contact from "../../components/sections/Contact.astro";
import Donate from "../../components/sections/Donate.astro";
import Team from "../../components/sections/Team.astro";
import Careers from "../../components/sections/Careers.astro";
import Navbar from "../../components/layout/Navbar";
import ProjectsCarousel from "../../components/features/ProjectsCarousel";
import NewsCarousel from "../../components/features/NewsCarousel";
import Footer from "../../components/layout/Footer";
import { TRANSLATIONS } from "../../i18n/translations";
import type { Language, Project, NewsItem } from "../../types";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "ru" } }];
}

export const prerender = true;

const { lang } = Astro.params as { lang: Language };
const t = TRANSLATIONS[lang];
const currentYear = new Date().getFullYear();

const projectEntries = await getCollection("projects");
const sortedProjects = projectEntries.sort((a, b) => a.data.id - b.data.id);
const titlesCount = sortedProjects.length;

const projects: Project[] = sortedProjects.map((e) => ({
  id: e.data.id,
  title: e.data[lang].title,
  description: e.data[lang].description,
  image: e.data.image,
  price: e.data[lang].price,
  tags: e.data[lang].tags,
  progress: e.data.progress,
  wishlistUrl: e.data.wishlistUrl,
}));

const newsEntries = await getCollection("news");
const news: NewsItem[] = newsEntries
  .sort((a, b) => a.id.localeCompare(b.id))
  .map((e) => ({
    isoDate: e.data.isoDate,
    date: e.data[lang].date,
    title: e.data[lang].title,
    image: e.data.image,
    summary: e.data[lang].summary,
    body: e.data[lang].body,
    type: e.data.type,
  }));
---

<Layout lang={lang} title={t.meta.title} description={t.meta.description} year={currentYear}>
  <Navbar lang={lang} t={t.nav} client:load />

  <main>
    <Hero t={t.hero} projects={projects} titlesCount={titlesCount} />
    <About t={t.about} lang={lang} titlesCount={titlesCount} />
    <Team t={t.team} lang={lang} partnerLinkLabels={t.partners.linkLabels} />
    <ProjectsCarousel t={t.projects} projects={projects} client:visible />
    <NewsCarousel news={news} t={t.news} lang={lang} client:visible />
    <Careers t={t.careers} lang={lang} />
    <Donate t={t.donate} />
    <Partners t={t.partners} lang={lang} />
    <Contact t={t.contact} />
  </main>

  <Footer t={t.footer} year={currentYear} lang={lang} nav={t.nav} client:visible />
</Layout>
